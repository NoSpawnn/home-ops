[Unit]
Description=Uptime-Kuma server
 
[Container]
ContainerName=%N
Image=docker.io/louislam/uptime-kuma:2
AutoUpdate=registry
PublishPort=9002:3001
 
HealthCmd=curl http://127.0.0.1:3001
UserNS=keep-id
 
#Network=services.network
 
Volume=%h/localappdata/uptime-kuma:/app/data
 
[Service]
Restart=always
TimeoutStartSec=300
 
[Install]
WantedBy=default.target
